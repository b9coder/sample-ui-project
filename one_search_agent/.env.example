OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model used specifically for the generate_a2ui dashboard-JSON subagent
# (see catalog.py's COMPOSITION_GUIDE) - this is the one call where
# structured-output reliability has mattered most in testing. Optional:
# falls back to OPENROUTER_MODEL if unset.
OPENROUTER_A2UI_MODEL=openai/gpt-5.1

# Path to the vulnerability_mcp project (parent dir containing the package),
# used to launch `python -m vulnerability_mcp.server` over stdio. This
# project REUSES that MCP server's tools (get_vulnerability_summary,
# get_risk_ranking, get_remediation_trend, resolve_application,
# resolve_user, list_applications, list_users) rather than redefining
# vulnerability retrieval from scratch.
VULN_MCP_PROJECT_DIR=/Users/nilesh/Documents/projects/claud-playground
PYTHON_BIN=python3
